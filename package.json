{
    "name": "@yaredfall/pluru",
    "private": false,
    "version": "0.0.1",
    "description": "Pluralization for Russian words",
    "keywords": [
        "plural",
        "pluralize",
        "pluralization",
        "russian",
        "ru"
    ],
    "files": [
        "dist"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "default": "./dist/index.mjs"
        }
    },
    "scripts": {
        "test": "vitest",
        "build": "tsdown",
        "release": "pnpm build && bumpp && pnpm publish --access public"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/YaredFall/pluru.git"
    },
    "bugs": {
        "url": "https://github.com/YaredFall/pluru/issues"
    },
    "author": "",
    "license": "MIT",
    "packageManager": "pnpm@10.9.0",
    "devDependencies": {
        "@biomejs/biome": "^2.4.15",
        "bumpp": "^11.1.0",
        "tsdown": "^0.22.0",
        "typescript": "^6.0.3",
        "vitest": "^4.1.6"
    }
}
